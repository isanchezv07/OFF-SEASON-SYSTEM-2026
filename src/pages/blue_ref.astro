---
import Layout from '../layouts/Layout.astro';
import BlueReferee from '../components/roles/referee/BLUE/BlueReferee';
---

<Layout title="FTC Local Scoring System - Blue Referee">
  <div id="auth-container" class="h-full" data-auth-required="true">
    <!-- Client-side rendering will determine whether to show login or controller -->
    <div id="controller-container">
      <BlueReferee client:only="react"  />
    </div>
  </div>
</Layout>